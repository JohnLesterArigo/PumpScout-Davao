rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().data.role == "admin";
    }

    function isVerifiedPriceReport() {
      return resource.data.status == "verified";
    }

    function isOwnFeedbackDoc() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function validFeedbackWrite() {
      return request.resource.data.userId == request.auth.uid
        && request.resource.data.reportId is string
        && request.resource.data.reportId.size() > 0
        && request.resource.data.type in ["reaction", "comment", "reply"]
        && request.resource.data.reaction is string
        && request.resource.data.comment is string
        && (
          (
            request.resource.data.type == "reaction"
            && request.resource.data.reaction in ["like", "disagree"]
            && request.resource.data.comment == ""
          )
          || (
            request.resource.data.type == "comment"
            && request.resource.data.reaction == ""
            && request.resource.data.comment.size() > 0
            && !("parentCommentId" in request.resource.data)
          )
          || (
            request.resource.data.type == "reply"
            && request.resource.data.reaction == ""
            && request.resource.data.comment.size() > 0
            && request.resource.data.parentCommentId is string
            && request.resource.data.parentCommentId.size() > 0
          )
        )
        && (!("userDisplayName" in request.resource.data)
          || request.resource.data.userDisplayName is string)
        && (!("userEmail" in request.resource.data)
          || request.resource.data.userEmail is string);
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());

      allow create: if signedIn()
        && request.auth.uid == userId
        && (!("role" in request.resource.data)
          || request.resource.data.role == "user");

      allow update: if isAdmin()
        || (
          signedIn()
          && request.auth.uid == userId
          && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(["role", "roleUpdatedAt"])
        );
    }

    match /priceReports/{reportId} {
      // Anyone can read verified community posts; owners/admins can read their own pending/rejected.
      allow read: if isAdmin()
        || isVerifiedPriceReport()
        || (signedIn() && resource.data.userId == request.auth.uid);

      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == "pending";

      allow update: if isAdmin()
        || (
          signedIn()
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == request.auth.uid
          && resource.data.status == "pending"
          && request.resource.data.status == "pending"
          && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny([
              "reviewedAt",
              "reviewedBy",
              "reviewedByEmail",
              "rejectionReason"
            ])
        );

      allow delete: if isAdmin();
    }

    match /stations/{stationId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;

      allow create: if isAdmin()
        && request.resource.data.userId is string
        && request.resource.data.isRead == false;

      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["isRead", "readAt"])
        && request.resource.data.isRead == true;

      allow delete: if isAdmin();
    }

    match /contributionFeedback/{feedbackId} {
      // Public read so every user can see agree/disagree notes on community posts.
      allow read: if true;

      allow create: if signedIn() && validFeedbackWrite();

      allow update: if signedIn()
        && isOwnFeedbackDoc()
        && validFeedbackWrite()
        && request.resource.data.type == "reaction"
        && request.resource.data.reportId == resource.data.reportId;

      allow delete: if isOwnFeedbackDoc() || isAdmin();
    }
  }
}
